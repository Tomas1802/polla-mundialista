# Copy to .env (local) and fill in. NEVER commit the real .env.

# HTTP port (Cloud Run injects PORT automatically).
PORT=8080

# PostgreSQL connection string.
#   Local:     postgres://polla:polla@localhost:5432/polla?sslmode=disable
#   Cloud SQL: postgres://USER:PASS@/DBNAME?host=/cloudsql/PROJECT:REGION:INSTANCE
DATABASE_URL=postgres://polla:polla@localhost:5432/polla?sslmode=disable

# Firebase project that issues the phone-auth ID tokens.
FIREBASE_PROJECT_ID=your-firebase-project-id
# Path to a service-account JSON for LOCAL dev. Leave empty on Cloud Run, which
# uses Application Default Credentials (the runtime service account).
FIREBASE_CREDENTIALS_FILE=

# football-data.org API token (free tier). Leave empty to disable match sync.
FOOTBALL_DATA_TOKEN=
COMPETITION_CODE=WC

# Secret used to sign session cookies. Use a long random string.
JWT_SECRET=change-me-to-a-long-random-secret

# Frontend origin allowed by CORS.
#   Local:      http://localhost:5173
#   Production: https://YOUR_GH_USER.github.io
ALLOWED_ORIGIN=http://localhost:5173

# true in production (cross-site cookie needs Secure + SameSite=None).
COOKIE_SECURE=false

# How long a session lasts (Go duration). 8760h = 1 year.
SESSION_TTL=8760h

# Minutes before kickoff a marcador locks. 0 = editable until kickoff.
LOCK_OFFSET_MINUTES=0

# How often (minutes) the sync policy is checked.
SYNC_INTERVAL_MINUTES=10

# LOCAL ONLY: passwordless login (enter a phone, no Firebase/OTP). When true,
# FIREBASE_PROJECT_ID is not required. MUST be false (or unset) in production.
DEV_LOGIN=false

# Admin emails (comma-separated). These accounts can view users and register
# official match results. Granted on login.
ADMIN_EMAILS=

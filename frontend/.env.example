# Copy to .env.local and fill in. All VITE_ vars are embedded in the built site
# (they are public by design — Firebase web config is not a secret).

# Backend API base URL (Cloud Run URL in production, local in dev).
VITE_API_BASE=http://localhost:8080

# Firebase web app config (Project settings → Your apps → Web app).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# LOCAL ONLY: when "true", the login screen asks only for name + phone (no OTP),
# matching the backend's DEV_LOGIN. Leave unset/false in production.
VITE_DEV_LOGIN=false
